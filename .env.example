# FinAgent Environment Variables
# Copy this file to .env and fill in your API keys

# ── LLM Provider: "anthropic" (direct API) or "bedrock" (AWS Bedrock) ───────
LLM_PROVIDER=bedrock

# ── Option A: Direct Anthropic API ──────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Option B: AWS Bedrock ────────────────────────────────────────────────────
# Required when LLM_PROVIDER=bedrock
# Leave blank to use IAM role / ~/.aws/credentials / AWS_PROFILE instead.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_SESSION_TOKEN=your_session_token_if_using_sts_assumed_role
AWS_REGION=us-east-1

# Bedrock model ID overrides (optional — defaults are set in tracing.py)
# Find available models: aws bedrock list-foundation-models --region us-east-1
# BEDROCK_MODEL_SONNET=us.anthropic.claude-sonnet-4-6
# BEDROCK_MODEL_HAIKU=us.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_MODEL_OPUS=us.anthropic.claude-opus-4-6-v1

# ── LlamaParse API Key (for PDF parsing of SEC filings) ─────────────────────
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# ── LangSmith Tracing (interview demo) ──────────────────────────────────────
# Get your API key at: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=finagent-demo
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # default, override if needed

# Optional: Data directory for ChromaDB persistence
DATA_DIR=./data
